<Page x:Class="MySchool.Pages.Settings"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MySchool.Pages"
      mc:Ignorable="d" 
      d:DesignWidth="928"
      Title="Settings"
      Background="{DynamicResource Brush.Background}">

    <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden">
        <StackPanel Margin="24" Orientation="Vertical">
            <TextBlock Text="Settings" Style="{StaticResource Text.Headline}" Margin="0,0,0,12"/>

            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Style="{StaticResource Text.Title}" Text="Personalization" Margin="0,0,0,5"/>
                    <TextBlock Style="{StaticResource Text.Body}" Text="Enter your name for a personalized greeting" Margin="0,0,0,8"/>
                    
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBox x:Name="UserNameTextBox" 
                                 Width="250" 
                                 Padding="8"
                                 VerticalContentAlignment="Center"
                                 Style="{DynamicResource TextBox.Standard}"
                                 TextChanged="UserNameTextBox_TextChanged"/>
                        <TextBlock Text="(Leave empty for time-based greeting)" 
                                   Style="{StaticResource Text.Body}" 
                                   Margin="12,0,0,0"
                                   Opacity="0.7"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Style="{StaticResource Text.Title}" Text="Appearance" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox x:Name="DarkModeToggle" VerticalAlignment="Center" IsChecked="False" Checked="DarkModeToggle_Checked" Unchecked="DarkModeToggle_Unchecked"/>
                        <TextBlock Text="Enable dark mode" Style="{StaticResource Text.Body}" Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Style="{StaticResource Text.Title}" Text="Font" Margin="0,0,0,5"/>
                    <TextBlock Style="{StaticResource Text.Body}" 
                               Text="Choose your preferred font for the application. The app must be restarted to apply font changes." 
                               Margin="0,0,0,8"
                               TextWrapping="Wrap"/>
  
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <ComboBox x:Name="FontComboBox" 
                                  Width="250" 
                                  Height="40"
                                  Background="{DynamicResource Brush.Surface}"
                                  Foreground="{DynamicResource Brush.TextPrimary}"
                                  BorderBrush="{DynamicResource Brush.Primary}"
                                  BorderThickness="2"
                                  Padding="12,8"
                                  FontSize="14"
                                  FontFamily="{StaticResource Font.Main}"
                                  SelectionChanged="FontComboBox_SelectionChanged">
                            <ComboBox.Resources>
                                <!-- ComboBox popup background -->
                                <Style TargetType="Border" x:Key="ComboBoxPopupBorder">
                                    <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </ComboBox.Resources>
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="FontFamily" Value="{StaticResource Font.Main}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ComboBoxItem">
                                                <Border x:Name="ItemBorder"
                                                       Background="{TemplateBinding Background}"
                                                       Padding="{TemplateBinding Padding}"
                                                       CornerRadius="4"
                                                       Margin="4,2">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="{Binding Source={StaticResource Brush.Primary}, Path=Color}" Opacity="0.1"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="{Binding Source={StaticResource Brush.Primary}, Path=Color}" Opacity="0.2"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
          
                        <Button x:Name="RestartAppButton" 
                                Style="{StaticResource Button.Primary}" 
                                Content="Restart App" 
                                Padding="16,8"
                                Margin="12,0,0,0"
                                Visibility="Collapsed"
                                Click="RestartAppButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Style="{StaticResource Text.Title}" Text="Timetable" Margin="0,0,0,5"/>
                    <TextBlock Style="{StaticResource Text.Body}" Text="Upload your school timetable using an AI assistant (ChatGPT, Claude, etc.)" Margin="0,0,0,8"/>
                    <Button x:Name="UploadTimetableButton" 
                            Style="{StaticResource Button.Primary}" 
                            Content="Upload Timetable" 
                            Padding="16,8"
                            HorizontalAlignment="Left"
                            Click="UploadTimetableButton_Click"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Style="{StaticResource Text.Title}" Text="Troubleshooting" Margin="0,0,0,5"/>
                    <TextBlock Style="{StaticResource Text.Body}" 
                               Text="Re-process your timetable to fix display issues or apply updated grouping rules" 
                               Margin="0,0,0,8"/>
                    <TextBlock Style="{StaticResource Text.Body}" 
                               Text="This will group consecutive periods with the same subject name into single periods and save the changes to your timetable." 
                               Margin="0,0,0,8"
                               Opacity="0.8"
                               TextWrapping="Wrap"/>
                    <TextBlock Style="{StaticResource Text.Body}" 
                               Text="Use this if: periods are appearing incorrectly split, or the app updated with new timetable processing features." 
                               Margin="0,0,0,8"
                               Opacity="0.8"
                               FontStyle="Italic"
                               TextWrapping="Wrap"/>
                    <Button x:Name="ReprocessTimetableButton" 
                            Style="{StaticResource Button.Secondary}" 
                            Content="Re-run Timetable Processing" 
                            Padding="16,8"
                            HorizontalAlignment="Left"
                            Click="ReprocessTimetableButton_Click"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Style="{StaticResource Text.Title}" Text="Weather Location" Margin="0,0,0,5"/>
                    <TextBlock Style="{StaticResource Text.Body}" Text="Configure location for weekend weather display" Margin="0,0,0,8"/>
                    
                    <TextBlock x:Name="CurrentLocationText" 
                               Style="{StaticResource Text.Body}" 
                               Text="Using device location" 
                               Margin="0,0,0,8"
                               FontWeight="SemiBold"/>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="RequestLocationButton" 
                                Style="{StaticResource Button.Primary}" 
                                Content="Request Location Permission" 
                                Padding="16,8"
                                Margin="0,0,8,0"
                                Click="RequestLocationButton_Click"/>
                        <Button x:Name="ManualLocationButton" 
                                Style="{StaticResource Button.Secondary}" 
                                Content="Set Manual Location" 
                                Padding="16,8"
                                Click="ManualLocationButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Style="{StaticResource Text.Title}" Text="About" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Vertical" Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Version:" 
                                       Style="{StaticResource Text.Body}" 
                                       FontWeight="SemiBold"
                                       Width="100"/>
                            <TextBlock x:Name="VersionText" 
                                       Text="Loading..." 
                                       Style="{StaticResource Text.Body}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Build Number:" 
                                       Style="{StaticResource Text.Body}" 
                                       FontWeight="SemiBold"
                                       Width="100"/>
                            <TextBlock x:Name="BuildNumberText" 
                                       Text="Loading..." 
                                       Style="{StaticResource Text.Body}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="Build Date:" 
                                       Style="{StaticResource Text.Body}" 
                                       FontWeight="SemiBold"
                                       Width="100"/>
                            <TextBlock x:Name="BuildDateText" 
                                       Text="Loading..." 
                                       Style="{StaticResource Text.Body}"/>
                        </StackPanel>
     
                        <Button x:Name="CheckUpdatesButton" 
                                Style="{StaticResource Button.Primary}" 
                                Content="Check for Updates" 
                                Padding="16,8"
                                HorizontalAlignment="Left"
                                Click="CheckUpdatesButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
